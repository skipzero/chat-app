    "clsx": "^2.1.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "mongodb": "^6.20.0",
    "next": "^16.2.7",
    "shadcn": "^4.13.0",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.4.1"
  },
  "devDependencies": {
    "@chatapp/config": "workspace:*",
    "@types/bun": "1.3.14",
    "typescript": "^5.9.3"
  },
  "packageManager": "bun@1.3.11"
}
