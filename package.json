{
  "name": "chatapp",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "zod": "^4.1.13",
      "@types/bun": "^1.3.4",
      "better-auth": "1.5.2",
      "lucide-react": "^0.546.0",
      "next-themes": "^0.4.6",
      "react": "^19.2.3",
      "react-dom": "^19.2.3",
      "sonner": "^2.0.5",
      "@types/react": "^19.2.10",
      "@types/react-dom": "^19.2.3",
      "tailwindcss": "^4.1.18"
    }
  },
  "scripts": {
    "dev": "NODE_ENV=development bun run --filter '*' dev",
    "build": "NODE_ENV=production bun run --filter '*' build",
    "check-types": "bun run --filter '*' check-types",
    "test": "bun run --filter '*' test",
    "test:jest": "bun run --filter '*' test:jest",
    "test:all": "bun run test:jest && bun run test",
    "dev:web": "bun run --filter web dev",
    "dev:server": "bun run --filter server dev"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@chatapp/env": "workspace:*",
    "@types/node": "^25.9.2",
