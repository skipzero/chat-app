{
  "name": "chatapp",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.2.2",
      "zod": "^4.1.13",
      "typescript": "^5",
      "@types/bun": "^1.3.4",
      "better-auth": "^1.4.18",
      "@types/express": "^5.0.1",
      "mongoose": "^8.14.0"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "bun run --filter '*' dev",
    "build": "bun run --filter '*' build",
    "check-types": "bun run --filter '*' check-types",
    "dev:native": "bun run --filter native dev",
    "dev:web": "bun run --filter web dev",
    "dev:server": "bun run --filter server dev"
  },
  "dependencies": {
    "@chatapp/env": "workspace:*",
    "@types/socket.io": "^3.0.2",
    "dotenv": "^17.3.1",
    "socket.io": "^4.8.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@chatapp/config": "workspace:*",
    "@types/bun": "^1.3.11",
    "typescript": "^5.9.3"
  },
  "packageManager": "bun@1.3.2"
}
