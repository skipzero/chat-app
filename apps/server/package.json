{
  "name": "server",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "build": "tsdown",
    "check-types": "tsc -b",
    "compile": "bun build --compile --minify --sourcemap --bytecode ./src/index.ts --outfile server",
    "dev": "bun run --hot src/index.ts",
    "start": "bun run dist/index.mjs",
    "test:jest": "jest --config jest.config.cjs",
    "test": "bun test ./tests"
  },
  "dependencies": {
    "@chatapp/auth": "workspace:*",
    "@chatapp/db": "workspace:*",
    "@chatapp/env": "workspace:*",
    "better-auth": "1.6.11",
    "bun-types": "^1.3.14",
    "dotenv": "^17.4.2",
    "express": "^5.1.0",
    "mongodb": "^6.20.0",
    "socket.io": "^4.8.1",
    "zod": "4.4.1"
  },
  "devDependencies": {
    "@chatapp/config": "workspace:*",
    "@types/bun": "1.3.14",
    "@types/express": "^5.0.1",
    "@types/jest": "^30.0.0",
    "@types/mocha": "^10.0.10",
    "jest": "^29.7.0",
    "ts-jest": "^29.3.1",
    "tsdown": "^0.16.5",
    "typescript": "^5"
  }
}
