{
  "name": "server",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "build": "tsdown",
    "check-types": "tsc -b",
    "compile": "bun build --compile --minify --sourcemap --bytecode ./src/index.ts --outfile server",
    "dev": "bun run --hot src/index.ts",
    "start": "bun run dist/index.mjs"
  },
  "dependencies": {
    "@chatapp/auth": "workspace:*",
    "@chatapp/db": "workspace:*",
    "@chatapp/env": "workspace:*",
    "better-auth": "1.6.11",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^5.1.0",
    "mongodb": "^6.20.0",
    "socket.io": "^4.8.1",
    "zod": "4.4.1"
  },
  "devDependencies": {
    "@chatapp/config": "workspace:*",
    "@types/bun": "1.3.14",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.1",
    "tsdown": "^0.16.5",
    "typescript": "^5"
  }
}
